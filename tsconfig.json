{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": [
      "ES2022"
    ],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "resolveJsonModule": true
  },
  "include": [
    "scripts/**/*.js"
  ]
}
